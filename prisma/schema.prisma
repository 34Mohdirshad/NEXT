// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows  Workflow[]
  executions WorkflowExecution[]

  @@map("users")
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  definition  Json     // Stores nodes and edges as JSON
  isTemplate  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  @@map("workflows")
}

model WorkflowExecution {
  id             String          @id @default(cuid())
  workflowId     String
  userId         String
  status         ExecutionStatus @default(PENDING)
  scope          ExecutionScope  @default(FULL_WORKFLOW)
  selectedNodes  Json?           // Array of node IDs for partial execution
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  duration       Int?            // Duration in milliseconds
  error          String?
  triggerRunId   String?         // Trigger.dev run ID

  workflow    Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeLogs    NodeExecutionLog[]

  @@index([workflowId])
  @@index([userId])
  @@map("workflow_executions")
}

model NodeExecutionLog {
  id          String          @id @default(cuid())
  executionId String
  nodeId      String
  nodeType    String
  nodeLabel   String?
  status      ExecutionStatus @default(PENDING)
  inputs      Json?
  outputs     Json?
  error       String?
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  duration    Int?            // Duration in milliseconds

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("node_execution_logs")
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

enum ExecutionScope {
  FULL_WORKFLOW
  SELECTED_NODES
  SINGLE_NODE
}
